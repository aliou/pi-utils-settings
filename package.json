{
  "name": "@aliou/pi-utils-settings",
  "version": "0.10.3",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Shared settings UI and config loader for pi extensions",
  "exports": {
    ".": "./index.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aliou/pi-utils-settings"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "*.ts",
    "components",
    "skills",
    "README.md"
  ],
  "pi": {
    "skills": [
      "skills"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm changeset publish"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.61.0 <1"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aliou/biome-plugins": "^0.4.0",
    "@biomejs/biome": "^2.4.3",
    "@changesets/cli": "^2.27.11",
    "@mariozechner/pi-coding-agent": "0.61.0",
    "@mariozechner/pi-tui": "0.61.0",
    "@types/node": "^25.0.10",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.26.1"
}
